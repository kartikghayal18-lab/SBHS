# Turn this on only after you create the database table from docs/database.sql.
VITE_USE_REMOTE_ERP=false

# Supabase project settings. Use the anon public key, not the service role key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# One shared ERP record id. Keep this same across deployments for one school.
VITE_ERP_STATE_ID=sbhs-main

# Cloudinary unsigned upload settings.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
